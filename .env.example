# FeeWars Arena — React App Environment
# Copy this file: copy .env.example .env
# Edit it:        notepad .env

# WalletConnect Project ID — get yours FREE at https://cloud.walletconnect.com
# Without this, WalletConnect-based wallets won't connect. MetaMask and Coinbase still work.
VITE_WC_PROJECT_ID=your_walletconnect_project_id_here

# Arena contract address (fill in after deploy)
VITE_ARENA_ADDRESS=

# Token contract address (fill in after BankrBot launch)
VITE_TOKEN_ADDRESS=
